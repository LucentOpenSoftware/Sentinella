{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentinella",
  "version": "0.1.0",
  "identifier": "com.sentinella.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sentinella",
        "width": 1080,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "splash",
        "title": "Sentinella",
        "url": "splash.html",
        "width": 580,
        "height": 340,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Lucent Open Software",
    "copyright": "Copyright (c) 2024-2026 Lucent Open Software. GPLv2.",
    "category": "Utility",
    "shortDescription": "Sentinella Antivirus Suite — Local-first endpoint protection",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
