{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentinella",
  "version": "0.1.4",
  "identifier": "com.sentinella.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sentinella",
        "width": 1080,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "splash",
        "title": "Sentinella",
        "url": "splash.html",
        "width": 580,
        "height": 340,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset:; connect-src ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "Lucent Open Software",
    "copyright": "Copyright (c) 2024-2026 Lucent Open Software. GPLv2.",
    "category": "Utility",
    "shortDescription": "Sentinella Antivirus Suite — Local-first endpoint protection",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../release/staging/windows/sentinelld.exe": "daemon/sentinelld.exe",
      "../../release/staging/windows/argusd.exe": "daemon/argusd.exe",
      "../../release/staging/windows/sentinella.exe": "daemon/sentinella-cli.exe",
      "../../release/staging/windows/freshclam.exe": "daemon/freshclam.exe",
      "../../release/staging/windows/libclamav.dll": "daemon/libclamav.dll",
      "../../release/staging/windows/libclammspack.dll": "daemon/libclammspack.dll",
      "../../release/staging/windows/libfreshclam.dll": "daemon/libfreshclam.dll",
      "../../release/staging/windows/zlib1.dll": "daemon/zlib1.dll",
      "../../release/staging/windows/bz2.dll": "daemon/bz2.dll",
      "../../release/staging/windows/iconv-2.dll": "daemon/iconv-2.dll",
      "../../release/staging/windows/json-c.dll": "daemon/json-c.dll",
      "../../release/staging/windows/libcrypto-3-x64.dll": "daemon/libcrypto-3-x64.dll",
      "../../release/staging/windows/libcurl.dll": "daemon/libcurl.dll",
      "../../release/staging/windows/libssl-3-x64.dll": "daemon/libssl-3-x64.dll",
      "../../release/staging/windows/libxml2.dll": "daemon/libxml2.dll",
      "../../release/staging/windows/pcre2-8.dll": "daemon/pcre2-8.dll",
      "../../release/staging/windows/pthreadVC3.dll": "daemon/pthreadVC3.dll",
      "../../release/staging/windows/certs": "daemon/certs",
      "../../release/staging/windows/runtime/config": "daemon/runtime/config",
      "../../release/staging/windows/runtime/argus/rules/yara": "daemon/runtime/argus/rules/yara",
      "../../release/staging/windows/runtime/argus/manifests": "daemon/runtime/argus/manifests",
      "../../release/staging/windows/runtime/rules": "daemon/runtime/rules",
      "../../release/staging/windows/runtime/signatures_bootstrap": "daemon/runtime/signatures_bootstrap",
      "../../release/staging/windows/LICENSE": "daemon/LICENSE",
      "../../release/staging/windows/NOTICE.md": "daemon/NOTICE.md"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/LucentOpenSoftware/Sentinella/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5RUQ3RDhCQTNBNUI4NjYKUldSbXVLV2ppMzN0YVlteFJZVy9tYmpwQ1hNRHNrRE5ZekdURVp1cEM2WTcxa2c2dnIrVG5nbi8K"
    }
  }
}
